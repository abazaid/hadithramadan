---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');

const mainMenu = [
	{ label: 'المدونة', href: '/blog' },
	{ label: 'اجزاء كتاب حديث رمضان', href: '/books' },
	{ label: 'عن الشيخ', href: '/about' },
	{ label: 'تواصل', href: '/contact' },
];
---

<header class="site-header">
	<div class="shell">
		<a class="brand" href="/" aria-label={SITE_TITLE}>
			<strong>{SITE_TITLE}</strong>
			<span>أرشيف علمي ومنهجي</span>
		</a>

		<nav aria-label="القائمة الرئيسية">
			<ul class="menu-root">
				{
					mainMenu.map((item) => (
						<li>
							<a class={pathname === item.href ? 'active' : undefined} href={item.href}>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: #fff;
		border-bottom: 1px solid var(--line);
	}

	.shell {
		width: min(1240px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1rem 0;
		display: grid;
		gap: 1rem;
	}

	.brand {
		display: inline-flex;
		flex-direction: column;
		text-decoration: none;
		color: #161616;
	}

	.brand strong {
		font-size: 1.15rem;
	}

	.brand span {
		font-size: 0.88rem;
		color: #777;
	}

	.menu-root {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
	}

	a {
		display: block;
		text-decoration: none;
		color: #222;
		padding: 0.55rem 0.9rem;
		border-radius: 8px;
	}

	.menu-root > li > a:hover,
	.menu-root > li > a.active {
		background: var(--accent-soft);
		color: #5f431d;
	}

	@media (max-width: 980px) {
		.shell {
			width: min(100% - 1rem, 1240px);
		}

		.menu-root {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0;
			border: 1px solid var(--line);
			border-radius: 10px;
			overflow: hidden;
		}

		.menu-root > li + li > a {
			border-top: 1px solid #efe6d8;
		}
	}
</style>
