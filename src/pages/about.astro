---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR_BIO, FACEBOOK_URL, SITE_AUTHOR, SITE_TITLE, SITE_URL, YOUTUBE_URL } from '../consts';

const pageTitle = `عن الشيخ | ${SITE_TITLE}`;
const pageDescription =
	'تعريف بالشيخ جواد عبد المحسن الهشلمون، وسيرته العلمية، ومنهجه في الكتابة، وروابط الوصول إلى كتبه ومقالاته.';
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: SITE_AUTHOR,
	url: `${SITE_URL}/about`,
	description: AUTHOR_BIO,
	sameAs: [FACEBOOK_URL, YOUTUBE_URL],
};
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'الرئيسية', item: SITE_URL },
		{ '@type': 'ListItem', position: 2, name: 'عن الشيخ', item: `${SITE_URL}/about` },
	],
};
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} schema={[personSchema, breadcrumbSchema]} />
		<style>
			.about-grid {
				display: grid;
				gap: 1rem;
			}

			.card {
				padding: 1.4rem;
			}

			.links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}

			.links a {
				display: inline-flex;
				padding: 0.55rem 0.9rem;
				border-radius: 999px;
				background: var(--accent-soft);
				text-decoration: none;
				font-weight: 700;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="surface card">
				<p class="eyebrow">نبذة تعريفية</p>
				<h1>{SITE_AUTHOR}</h1>
				<p>{AUTHOR_BIO}</p>
			</section>

			<div class="about-grid">
				<section class="surface card">
					<h2>المسار العلمي والمنهجي</h2>
					<p>
						يركّز الشيخ في كتاباته على التأصيل الشرعي، وربط النصوص بالواقع، ومعالجة القضايا الفكرية والسياسية
						والتاريخية بلغة واضحة ومنهج تحليلي.
					</p>
				</section>

				<section class="surface card">
					<h2>المؤلفات</h2>
					<p>
						تضم المدونة سلسلة كتب حديث رمضان الكاملة (26 جزءًا) بالإضافة إلى أرشيف مقالات علمية ممتد عبر سنوات.
					</p>
					<p><a href="/books">استعراض جميع أجزاء الكتب</a></p>
				</section>

				<section class="surface card">
					<h2>روابط رسمية</h2>
					<div class="links">
						<a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">Facebook</a>
						<a href={YOUTUBE_URL} target="_blank" rel="noopener noreferrer">YouTube</a>
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
