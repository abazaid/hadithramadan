	{ number: 21, title: 'حديث رمضان 21', href: 'https://drive.google.com/file/d/1xlEbGG_L8_tkLS4v6hZatiX9pEkWFLi6/view?usp=share_link', note: 'رجال نصروا الرسول' },
	{ number: 22, title: 'حديث رمضان 22', href: 'https://drive.google.com/file/d/1Tf0vVcMZSirKq31ucoRF5FvfK8rEFnDD/view?usp=sharing', note: 'حديث القلب لمن يحب' },
	{ number: 23, title: 'حديث رمضان 23', href: 'https://drive.google.com/file/d/1Kg8YMsGjItz864db-T2K6bw43t0AAJie/view?usp=sharing' },
	{ number: 24, title: 'حديث رمضان 24', href: 'https://drive.google.com/file/d/1Jm7GawKTHMOx_KQ1TvVxg6z8kuF2svq-/view?usp=sharing', note: 'قصة وشعر' },
	{ number: 25, title: 'حديث رمضان 25', href: 'https://drive.google.com/file/d/1PZHtRfWefM5CEGGoye8Gd5IXdWxS9vVS/view?usp=sharing' },
	{ number: 26, title: 'حديث رمضان 26', href: 'https://drive.google.com/file/d/1sqAmSSSRBqp_UAYUpEFd0tiR72I2rqWo/view?usp=sharing' },
];

const pageTitle = 'كتب حديث رمضان كاملة';
const pageDescription =
	'صفحة تجمع جميع أجزاء كتب حديث رمضان للشيخ جواد عبد المحسن بترتيب واضح وروابط مباشرة، مع فهرسة منظمة تسهّل الوصول إلى الأجزاء الكاملة والتحميل السريع.';
const keywords = [
	'كتب حديث رمضان',
	'أجزاء كتاب حديث رمضان',
	'تحميل كتب حديث رمضان',
	'الشيخ جواد عبد المحسن',
	'حديث رمضان pdf',
];
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} keywords={keywords} />
		<style>
			.books-hero {
				display: grid;
				grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
				gap: 1rem;
			}

			.hero-card,
			.meta-card,
			.library-card {
				padding: 1.7rem;
			}

			.hero-card h1 {
				max-width: 10ch;
				margin-bottom: 1rem;
			}

			.hero-card p,
			.meta-card p {
				color: rgba(var(--olive), 0.95);
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				margin-top: 1.4rem;
			}

			.primary-link,
			.secondary-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.92rem 1.2rem;
				border-radius: 999px;
				font-weight: 700;
				text-decoration: none;
			}

			.primary-link {
				background: #21362d;
				color: #f8f4ea;
			}

			.secondary-link {
				background: var(--accent-soft);
				color: var(--accent-strong);
			}

			.meta-list {
				display: grid;
				gap: 0.9rem;
				margin-top: 1rem;
			}

			.meta-item {
				padding: 1rem 1.1rem;
				border-radius: 20px;
				background: rgba(255, 255, 255, 0.68);
				border: 1px solid rgba(35, 53, 45, 0.08);
			}

			.meta-item strong {
				display: block;
				margin-bottom: 0.25rem;
			}

			.library-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				margin-top: 1.2rem;
			}

			.book-card {
				display: grid;
				gap: 0.8rem;
				padding: 1.2rem;
				border-radius: 24px;
				background: rgba(255, 255, 255, 0.82);
				border: 1px solid rgba(35, 53, 45, 0.08);
			}

			.book-top {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}

			.book-number {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 3rem;
				height: 3rem;
				padding: 0 0.7rem;
				border-radius: 999px;
				background: #21362d;
				color: #f8f4ea;
				font-weight: 700;
			}

			.book-card h2 {
				font-size: 1.25rem;
				margin: 0;
			}

			.book-card p {
				margin: 0;
				color: rgba(var(--muted), 1);
				font-size: 0.96rem;
			}

			.book-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.85rem 1rem;
				border-radius: 999px;
				background: var(--accent-soft);
				color: var(--accent-strong);
				font-weight: 700;
				text-decoration: none;
			}

			@media (max-width: 980px) {
				.books-hero,
				.library-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="books-hero">
				<div class="hero-card surface">
					<p class="eyebrow">مكتبة الكتب</p>
					<h1>أجزاء كتاب حديث رمضان</h1>
					<p>
						هذه الصفحة تجمع جميع أجزاء كتب حديث رمضان في مكان واحد، بترتيب واضح وروابط مباشرة تسهّل الوصول
						إلى كل جزء من أجزاء السلسلة. تم إعدادها بصياغة أوضح وفهرسة أنسب للزائر ومحركات البحث.
					</p>
					<div class="hero-actions">
						<a class="primary-link" href="#library">تصفح جميع الأجزاء</a>
						<a class="secondary-link" href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">التواصل عبر فيسبوك</a>
					</div>
				</div>

				<aside class="meta-card surface">
					<p class="eyebrow">معلومات سريعة</p>
					<h2>فهرس واحد لجميع الكتب</h2>
					<div class="meta-list">
						<div class="meta-item">
							<strong>{books.length} جزءًا</strong>
							<span>روابط مرتبة لأجزاء حديث رمضان كاملة</span>
						</div>
						<div class="meta-item">
							<strong>تنظيم أوضح</strong>
							<span>عرض مريح للقراءة والوصول السريع لكل جزء</span>
						</div>
						<div class="meta-item">
							<strong>صفحة قوية سيو</strong>
							<span>عنوان ووصف ومحتوى مخصص لفهرسة صفحة الكتب بشكل أفضل</span>
						</div>
					</div>
				</aside>
			</section>

			<section id="library" class="library-card surface">
				<div class="section-head">
					<div>
						<p class="eyebrow">الفهرس الكامل</p>
						<h2>جميع أجزاء كتاب حديث رمضان</h2>
					</div>
					<p>روابط الأجزاء مرتبة كما وردت في الصفحة الأصلية، مع تحسين العرض والتنظيم داخل الموقع الجديد.</p>
				</div>

				<div class="library-grid">
					{
						books.map((book) => (
							<article class="book-card">
								<div class="book-top">
									<h2>{book.title}</h2>
									<span class="book-number">{book.number}</span>
								</div>
								<p>{book.note ? `وصف مختصر: ${book.note}` : 'جزء من سلسلة كتب حديث رمضان.'}</p>
								<a class="book-link" href={book.href} target="_blank" rel="noopener noreferrer">
									فتح الجزء
								</a>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
