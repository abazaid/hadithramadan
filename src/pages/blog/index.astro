---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPostUrl, getSortedPosts } from '../../lib/blog';

const posts = await getSortedPosts();
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<BaseHead title={`الأرشيف | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive-hero {
				padding: 1.8rem;
			}

			.archive-hero h1 {
				max-width: 12ch;
			}

			.archive-hero p {
				max-width: 46rem;
			}

			.archive-list {
				display: grid;
				gap: 1rem;
			}

			.archive-item {
				display: grid;
				grid-template-columns: 170px minmax(0, 1fr) auto;
				gap: 1rem;
				align-items: start;
				padding: 1.25rem 1.35rem;
			}

			.archive-item .date {
				color: rgba(var(--muted), 1);
				font-size: 0.95rem;
				margin-top: 0.2rem;
			}

			.archive-item h3 {
				margin-bottom: 0.35rem;
				font-size: 1.45rem;
			}

			.archive-item p {
				margin: 0;
			}

			.archive-item .open-link {
				display: inline-flex;
				align-self: center;
				padding: 0.75rem 1rem;
				border-radius: 999px;
				background: var(--accent-soft);
				text-decoration: none;
				font-weight: 700;
			}

			@media (max-width: 900px) {
				.archive-item {
					grid-template-columns: 1fr;
				}

				.archive-item .open-link {
					justify-self: start;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-hero surface">
				<p class="eyebrow">الأرشيف الكامل</p>
				<h1>كل التدوينات في فهرس أوضح وأسهل.</h1>
				<p>
					هذه الصفحة تعرض كامل محتوى المدونة في قائمة مريحة للقراءة والمراجعة، مع روابط عربية حديثة لكل تدوينة وتنظيم واضح وسهل التصفح.
				</p>
			</section>

			<section class="archive-list">
				{
					posts.map((post) => (
						<article class="archive-item surface">
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<div>
								<h3>
									<a href={getPostUrl(post)}>{post.data.title}</a>
								</h3>
								<p>{post.data.description}</p>
							</div>
							<a class="open-link" href={getPostUrl(post)}>فتح التدوينة</a>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>


